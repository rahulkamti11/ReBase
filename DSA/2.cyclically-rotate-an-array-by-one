//GfG question link:
//https://www.geeksforgeeks.org/problems/cyclically-rotate-an-array-by-one2614/1

class Solution {
  public:
    void rotate(vector<int> &arr) {
        int len = arr.size();
        
        int last = arr[len-1];
        for(int i=len ; i>0 ; i--){
            arr[i-1] = arr[i-2];
        }
        arr[0] = last ;
    }
};
